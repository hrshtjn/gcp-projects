# Keycloak Configuration
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/gcp-poc/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=gcp-wif-client
KEYCLOAK_CLIENT_SECRET=my-super-secret-client-secret

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# WIF Configuration Path
# Path to the JSON configuration file generated by gcloud (see README.md)
GOOGLE_APPLICATION_CREDENTIALS=client-config.json

# Path where fetch_token.py should save the token
# Ensure this matches the `credential_source.file` path in client-config.json
TOKEN_FILE_PATH=keycloak_token.txt